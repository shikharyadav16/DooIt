{
  "name": "todo-backend",
  "version": "1.0.0",
  "description": "Production-grade Express + TypeScript backend",
  "main": "dist/index.js",
  "scripts": {
    "dev": "nodemon --watch src --exec ts-node src/index.ts",
    "build": "tsc",
    "start": "node dist/index.js",
    "prod": "npm run build && npm run start",
    "clean": "rmdir /s /q dist"
  },
  "dependencies": {
    "bcrypt": "^6.0.0",
    "cookie-parser": "^1.4.7",
    "dotenv": "^17.4.2",
    "express": "^5.2.1",
    "jsonwebtoken": "^9.0.3",
    "mongoose": "^9.4.1"
  },
  "devDependencies": {
    "@types/bcrypt": "^6.0.0",
    "@types/cookie-parser": "^1.4.10",
    "@types/express": "^5.0.6",
    "@types/jsonwebtoken": "^9.0.10",
    "@types/node": "^22.5.0",
    "nodemon": "^3.1.0",
    "ts-node": "^10.9.2",
    "typescript": "^6.0.2"
  }
}